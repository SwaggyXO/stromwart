# Copy to .env.local and fill in your Auth0 credentials
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_auth0_client_id

# Optional: set a custom domain to mask the raw tenant slug in the URL bar
# (e.g. auth.yourdomain.com — must be configured in Auth0 Dashboard → Branding → Custom Domains)
# When set, this takes priority over VITE_AUTH0_DOMAIN in the Auth0Provider.
VITE_AUTH0_CUSTOM_DOMAIN=

# Required for Live Event dashboard — OpenAPI has no GET /events/active
# Paste a live event UUID created via POST /v1/events (or pass ?event_id= on the URL)
VITE_ACTIVE_EVENT_ID=
